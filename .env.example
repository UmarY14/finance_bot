# Telegram
BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL (local / VPS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_bot
DB_USER=botuser
DB_PASS=your_db_password_here

